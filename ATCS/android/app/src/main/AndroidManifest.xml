<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required by the installed @exxili/capacitor-nfc plugin: Capacitor's Bridge
         calls NFCPlugin.handleOnResume() on every activity resume regardless of
         whether the app uses NFC, and that call throws a SecurityException (crashing
         the app on launch) without this permission declared. -->
    <uses-permission android:name="android.permission.NFC" />
    <!-- Required by MainActivity.bindToWifiNetwork(): ConnectivityManager.requestNetwork()
         throws a SecurityException without this permission. It's a "normal" (not dangerous)
         permission — granted automatically at install time, no runtime prompt needed. -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- [STEP 7] Location permissions required for GPS/live-location sharing.
         Without these declared in the manifest the app simply does not appear
         in Android's Location Permission settings and navigator.geolocation
         immediately returns PERMISSION_DENIED — silently terminating live-share
         sessions and preventing SOS location broadcasts.
         ACCESS_FINE_LOCATION allows GPS-level precision.
         ACCESS_COARSE_LOCATION is required by the Android SDK alongside FINE.
         Both are "dangerous" permissions that also require a runtime prompt at
         first use, which the WebView geolocation API triggers automatically. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- [STEP 8] Required for the Beep/Find-User feature: allows the app to
         trigger the phone's vibration motor when a Beep is received. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- [STEP 8] Required for persistent live-location sharing when the app
         is backgrounded or the screen is locked. Without this, Android 9+
         throttles or kills GPS access for non-foreground apps. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
</manifest>
